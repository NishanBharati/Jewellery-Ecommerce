PORT=5001

# PostgreSQL Connection
DATABASE_URL="postgresql://your_database_user:your_database_password@localhost:5432/jewellery_db?schema=public"

# Individual DB Config (required by db.js)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jewellery_db
DB_USER=your_database_user
DB_PASSWORD=your_database_password

STORAGE=cloudinary

# JWT Secrets
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_minimum_32_characters_long

NODE_ENV=development

# Email Configuration (Gmail with App Passwords)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# Super Admin Credentials (auto-created on server start)
SUPER_ADMIN_EMAIL=admin@jewellery.com
SUPER_ADMIN_PASSWORD=your_strong_admin_password
SUPER_ADMIN_NAME=Super Admin

# Cloudinary Configuration (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
